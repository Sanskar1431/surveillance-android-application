<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:app="http://schemas.android.com/apk/res-auto">

    <style name="Theme.MyCamera" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primaryVariant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Calculator Girl Theme Styles -->
    <style name="CalcBtn" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:textSize">26sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">36dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CalcBtn.Number">
        <item name="android:backgroundTint">@color/calc_btn_num</item>
        <item name="android:textColor">@color/calc_text</item>
        <item name="rippleColor">@color/primary</item>
    </style>

    <style name="CalcBtn.Operator">
        <item name="android:backgroundTint">@color/calc_btn_op</item>
        <item name="android:textColor">@color/calc_text</item>
    </style>

    <style name="CalcBtn.Action">
        <item name="android:backgroundTint">@color/calc_btn_action</item>
        <item name="android:textColor">@color/calc_text</item>
    </style>

    <style name="CalcBtn.Equal">
        <item name="android:backgroundTint">@color/calc_btn_equal</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="TimeButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="backgroundTint">#22000000</item>
        <item name="cornerRadius">20dp</item>
    </style>
</resources>